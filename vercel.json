{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://cdn.socket.io https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://bizrnjpmsyxdsflgpxcl.supabase.co https://placehold.co; connect-src 'self' https://bizrnjpmsyxdsflgpxcl.supabase.co wss://bizrnjpmsyxdsflgpxcl.supabase.co https://ilove-delicitas-admin.onrender.com https://viacep.com.br https://nominatim.openstreetmap.org; media-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none';" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ilove-delicitas-admin.onrender.com/api/$1"
    },
    {
      "source": "/config.js",
      "destination": "/config.js"
    },
    {
      "source": "/pagamento-pix.html",
      "destination": "/pagamento-pix.html"
    },
    {
      "source": "/",
      "destination": "/src/pages/index.html"
    },
    {
      "source": "/cardapio",
      "destination": "/src/pages/cardapio.html"
    },
    {
      "source": "/carrinho",
      "destination": "/src/pages/carrinho.html"
    },
    {
      "source": "/checkout",
      "destination": "/src/pages/checkout.html"
    },
    {
      "source": "/acompanhamento",
      "destination": "/src/pages/acompanhamento.html"
    },
    {
      "source": "/pedido-confirmado",
      "destination": "/src/pages/pedido-confirmado.html"
    },
    {
      "source": "/login",
      "destination": "/src/pages/login.html"
    },
    {
      "source": "/cadastro",
      "destination": "/src/pages/cadastro.html"
    },
    {
      "source": "/esqueci-senha",
      "destination": "/src/pages/esqueci-senha.html"
    },
    {
      "source": "/reset-password",
      "destination": "/src/pages/reset-password.html"
    },
    {
      "source": "/perfil",
      "destination": "/src/pages/perfil.html"
    },
    {
      "source": "/meus-pedidos",
      "destination": "/src/pages/meus-pedidos.html"
    },
    {
      "source": "/admin",
      "destination": "/src/pages/admin.html"
    },
    {
      "source": "/alert.mp3",
      "destination": "/src/pages/alert.mp3.mp3"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
